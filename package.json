{
    "name": "@strata-eve/esi",
    "description": "A fully typed, auto-generated wrapper for the Eve Online ESI.",
    "version": "0.0.1",
    "main": "./dist/index.js",
    "typings": "./dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "eve-online",
        "esi",
        "eve",
        "api",
        "wrapper",
        "typescript",
        "sso"
    ],
    "scripts": {
        "lint": "eslint . --max-warnings 0",
        "type-check": "tsc --noEmit",
        "build": "tsdown",
        "dev": "tsx src/index.ts",
        "generate": "tsx scripts/generate.ts",
        "prepublishOnly": "yarn lint && yarn type-check && yarn build"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/strata-eve/esi.git"
    },
    "license": "MIT",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.6.0",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.4.0",
        "jiti": "^2.6.1",
        "prettier": "^3.8.2",
        "tsdown": "^0.21.7",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.1"
    },
    "dependencies": {
        "jose": "^6.2.2"
    }
}
